    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
